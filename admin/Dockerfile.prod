FROM node:20-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine

COPY nginx.conf /etc/nginx/conf.d/default.conf
# SPA is served under the `/admin/` URL prefix, so the built files must live
# under the matching directory inside the nginx document root.
COPY --from=build /app/dist /usr/share/nginx/html/admin

EXPOSE 80


# Production example. Copy to `.env` on the server and replace ALL placeholders.
# Never commit a real `.env` file. Pass secrets to the company separately.

APP_ENV=prod
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

POSTGRES_DB=aerotrust
POSTGRES_USER=aerotrust
POSTGRES_PASSWORD=replace-with-strong-password

# Password in DATABASE_URL must match POSTGRES_PASSWORD.
DATABASE_URL=postgresql+asyncpg://aerotrust:replace-with-strong-password@postgres:5432/aerotrust
REDIS_URL=redis://redis:6379/0

ADMIN_JWT_SECRET=replace-with-strong-random-secret
ADMIN_JWT_ALGORITHM=HS256
ADMIN_ACCESS_TOKEN_TTL_MINUTES=480
ADMIN_PASSWORD_HASH_ITERATIONS=390000

TELEGRAM_BOT_TOKEN=replace-with-real-token
BOT_POLLING_TIMEOUT=30
BOT_FORCE_IPV4=true
BOT_RATE_LIMIT_ENABLED=true
BOT_RATE_LIMIT_MAX_EVENTS=10
BOT_RATE_LIMIT_WINDOW_SECONDS=10
BOT_RATE_LIMIT_BLOCK_SECONDS=30

UPLOADS_ROOT=/app/uploads
MAX_REPORT_TEXT_LENGTH=4000
MAX_ATTACHMENT_SIZE_MB=10
MAX_ATTACHMENTS_PER_REPORT=5
ALLOWED_DOCUMENT_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.txt,.csv,.jpg,.jpeg,.png
ALLOWED_DOCUMENT_MIME_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,text/plain,text/csv,image/jpeg,image/png

# Public host port for admin UI + API proxy (nginx listens on 80 inside the container).
# Prefer putting TLS termination (nginx/caddy/traefik) in front and keep this internal or behind firewall.
ADMIN_HOST_PORT=80

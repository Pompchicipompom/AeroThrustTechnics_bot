# App
APP_ENV=development
APP_NAME=aerotrust-bot
APP_DOMAIN=example.com
APP_BASE_URL=https://example.com

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_WEBHOOK_SECRET=replace_me
TELEGRAM_WEBHOOK_URL=https://example.com/webhook/telegram

# Database
POSTGRES_DB=aerotrust
POSTGRES_USER=aerotrust
POSTGRES_PASSWORD=replace_me
DATABASE_URL=postgresql+psycopg://aerotrust:replace_me@db:5432/aerotrust

# Redis
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=replace_me
ADMIN_JWT_SECRET=replace_me

# Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=20

# Invite codes
INVITE_CODE_LENGTH=10

# Admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace_me

# Analytics
TIMEZONE=Europe/Moscow
